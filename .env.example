# ---------- 通用 ----------
PROJECT_NAME=Flow2API
ENVIRONMENT=development
# 逗号分隔的允许跨域来源
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- 安全 ----------
# 生产环境务必替换为随机长字符串: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_super_secret_key_for_jwt_signing
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---------- 数据库 ----------
POSTGRES_USER=flow
POSTGRES_PASSWORD=flow_pass
POSTGRES_DB=flow2api
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------- 对象存储 (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
MEDIA_PUBLIC_ENDPOINT=http://localhost:18000/media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=flow2api
S3_REGION=us-east-1

# ---------- 初始管理员 (seed 脚本使用) ----------
FIRST_ADMIN_EMAIL=admin@flow2api.com
FIRST_ADMIN_PASSWORD=admin12345

# ---------- FLOW 适配层(真实 Google Flow 协议)----------
# 对 FLOW 上游的全局最大并发(账号池总闸门)
FLOW_GLOBAL_CONCURRENCY=8
# 单账号最大并发
FLOW_PER_ACCOUNT_CONCURRENCY=2
# FLOW 请求超时(秒)
FLOW_REQUEST_TIMEOUT=120
# 出视频轮询最大等待 / 间隔(秒)
FLOW_VIDEO_MAX_WAIT=600
FLOW_VIDEO_POLL_INTERVAL=3
# 用 curl_cffi 模拟 Chrome TLS 指纹(注意:本机 curl_cffi 0.7.4 不支持 chrome136,用 chrome124)
FLOW_USE_CURL=true
FLOW_IMPERSONATE=chrome124
# reCAPTCHA 引擎:优先使用无头 Chrome broker 执行官方 Enterprise JS 获取 token,纯 HTTP anchor/reload 作为兜底。
FLOW_HEADLESS=true
FLOW_CHROME_PATH=
FLOW_PROFILES_DIR=/data/flow_profiles
FLOW_TOKEN_TIMEOUT=90
# 全局默认代理(账号可单独覆盖)。reCAPTCHA broker/协议请求与 Flow HTTP 提交走同一代理->同一出口 IP。
# 例: http://user:pass@host:port 或 socks5://user:pass@host:port。留空=直连。
FLOW_PROXY=
# reCAPTCHA 分数有波动:每次失败重新取新 token 重试,重试期间不冷却账号
FLOW_RECAPTCHA_RETRIES=5
FLOW_RECAPTCHA_RETRY_DELAY=4
# 账号冷却(秒):鉴权/限流短冷却,配额耗尽长冷却
FLOW_AUTH_COOLDOWN=120
FLOW_QUOTA_COOLDOWN=3600

# ---------- 额度默认值 ----------
DEFAULT_DAILY_IMAGE_QUOTA=200
DEFAULT_DAILY_VIDEO_QUOTA=20
# 单用户每分钟最大请求数
USER_RATE_LIMIT_PER_MIN=30

# ---------- 前端 ----------
NEXT_PUBLIC_API_BASE=http://localhost:18000
NEXT_PUBLIC_WS_BASE=ws://localhost:18000
